generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  plan             Plan           @default(FREE)
  creditsRemaining Int            @default(100)
  creditsResetAt   DateTime       @default(now())
  stripeCustomerId String?
  stripeSubId      String?
  accounts         Account[]
  sessions         Session[]
  apiKeys          ApiKey[]
  activeWorkflows  UserWorkflow[]
  executions       Execution[]
  createdAt        DateTime       @default(now())
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   String
  key       String
  createdAt DateTime @default(now())

  @@unique([userId, service])
}

model Workflow {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String
  longDescription String?        @db.Text
  category        String
  creditsPerRun   Int
  frequency       String
  icon            String
  features        String[]
  integrations    String[]
  configSchema    Json
  isActive        Boolean        @default(true)
  userWorkflows   UserWorkflow[]
  createdAt       DateTime       @default(now())
}

model UserWorkflow {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowId String
  workflow   Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  config     Json
  isActive   Boolean     @default(false)
  schedule   String?
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  executions Execution[]
  createdAt  DateTime    @default(now())

  @@unique([userId, workflowId])
}

model Execution {
  id             String       @id @default(cuid())
  userWorkflowId String
  userWorkflow   UserWorkflow @relation(fields: [userWorkflowId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         ExecStatus   @default(PENDING)
  creditsUsed    Int
  result         Json?
  error          String?      @db.Text
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
}

enum Plan {
  FREE
  PRO
}

enum ExecStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}
